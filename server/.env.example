# ─── Template .env untuk server ─────────────────────────────────
# Salin file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke GitHub!
#
# cp .env.example .env

NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
# Dapatkan dari: MongoDB Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appName>

# JWT Secret — ganti dengan string acak yang panjang
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ganti_dengan_random_string_yang_panjang_dan_aman

JWT_EXPIRE=7d

# URL frontend (untuk CORS)
CLIENT_URL=http://localhost:5173
